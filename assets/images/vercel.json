{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/construction", "destination": "/civilengineering.html" },
    { "source": "/realestate", "destination": "/realestate.html" },
    { "source": "/interiordesign", "destination": "/interiordesign.html" },
    { "source": "/localityhub", "destination": "/localityhub.html" },
    { "source": "/trustcenter", "destination": "/trustcenter.html" },
    { "source": "/contactus", "destination": "/contactus.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/src/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
